{
  "manifest_version": 3,
  "name": "histree",
  "version": "0.1.2",
  "description": "Manage each tab's browsing history as a tree. Return to the original page with one click, even after branching.",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage",
    "sidePanel",
    "favicon"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open History Tree"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
